{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/knoxhack/ECHO-Release-Index/main/schemas/module-release-manifest.schema.json",
  "title": "ECHO Module Release Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "releaseId", "generatedAt", "sourceRepo", "provenance", "contentGraphEvidence", "runtimeConformanceEvidence", "modules"],
  "properties": {
    "schemaVersion": { "const": "echo.module.release.v1" },
    "releaseId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceRepo": { "type": "string", "minLength": 1 },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sourceRepo", "generatedBy", "attestation"],
      "properties": {
        "sourceRepo": { "type": "string", "minLength": 1 },
        "commitSha": { "type": "string" },
        "workflow": { "type": "string" },
        "workflowRef": { "type": "string" },
        "runId": { "type": "string" },
        "runAttempt": { "type": "string" },
        "refName": { "type": "string" },
        "eventName": { "type": "string" },
        "generatedBy": { "const": "scripts/generate-module-release.mjs" },
        "attestation": {
          "type": "object",
          "additionalProperties": true,
          "required": ["action", "subjectChecksums"],
          "properties": {
            "action": { "const": "actions/attest@v4" },
            "subjectChecksums": { "const": "echo-module-release.tar.gz.sha256" }
          }
        }
      }
    },
    "contentGraphEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "filename", "sha256", "size", "runtimeTarget", "buildMode", "schemaVersion"],
      "properties": {
        "kind": { "const": "content-graph-evidence" },
        "filename": { "const": "content-graph-evidence.json" },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "size": { "type": "integer", "minimum": 0 },
        "downloadUrl": { "type": "string" },
        "runtimeTarget": { "const": "content-graph" },
        "buildMode": { "const": "generated" },
        "schemaVersion": { "const": "echo.content_graph.evidence.v1" }
      }
    },
    "runtimeConformanceEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["kind", "filename", "sha256", "size", "runtimeTarget", "hostId", "buildMode", "schemaVersion", "summary"],
        "properties": {
          "kind": { "const": "runtime-conformance" },
          "filename": { "pattern": "^[a-z0-9_-]+-runtime-conformance\\.json$" },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 },
          "downloadUrl": { "type": "string" },
          "runtimeTarget": { "enum": ["echo_native", "neoforge", "echo_runtime_standalone", "standalone_engine"] },
          "hostId": { "enum": ["echo_native", "neoforge", "echo_runtime_standalone", "standalone_engine"] },
          "buildMode": { "const": "generated" },
          "schemaVersion": { "const": "echo.runtime.conformance.v1" },
          "summary": {
            "type": "object",
            "required": ["status", "supported", "adapted", "fallback", "blocked"],
            "properties": {
              "status": { "enum": ["pass", "warning", "fail"] },
              "supported": { "type": "integer", "minimum": 0 },
              "adapted": { "type": "integer", "minimum": 0 },
              "fallback": { "type": "integer", "minimum": 0 },
              "blocked": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["moduleId", "version", "descriptor", "requires", "optional", "artifacts"],
        "properties": {
          "moduleId": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "descriptor": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": { "const": "META-INF/echo.mod.json" },
              "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
            }
          },
          "requires": { "type": "array" },
          "optional": { "type": "array" },
          "artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["kind", "filename", "sha256", "size"],
              "properties": {
                "kind": { "enum": ["echo-addon", "neoforge", "standalone", "sources", "content-graph"] },
                "filename": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
                "size": { "type": "integer", "minimum": 0 },
                "downloadUrl": { "type": "string" },
                "runtimeTarget": { "type": "string" },
                "buildMode": { "enum": ["compiled-runtime", "source-packaged", "generated", null] },
                "contains": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
