{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/knoxhack/ECHO-SDK/main/schemas/content-graph.schema.json",
  "title": "ECHO Content Graph",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "generatedAt", "modules", "nodes", "edges"],
  "properties": {
    "schemaVersion": { "const": "echo.content_graph.v1" },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*:[a-zA-Z0-9_/.-]+$"
    },
    "moduleId": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9_-]*$" },
    "addonId": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9_-]*$" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "content-graph-node.schema.json" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "content-graph-edge.schema.json" }
    },
    "unresolvedReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "context"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "context": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "moduleId": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["generatedBy", "generatedAt"],
      "properties": {
        "generatedBy": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "minLength": 1 },
        "sourceRepo": { "type": "string" },
        "commitSha": { "type": "string" }
      }
    }
  }
}
