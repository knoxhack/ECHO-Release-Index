{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/knoxhack/ECHO-Release-Index/main/schemas/channel.schema.json",
  "title": "ECHO Channel",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "stability"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "stability": { "enum": ["stable", "beta", "alpha", "experimental", "internal"] }
  }
}
