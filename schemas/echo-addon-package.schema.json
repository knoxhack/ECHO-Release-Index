{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/knoxhack/ECHO-Release-Index/main/schemas/echo-addon-package.schema.json",
  "title": "ECHO Addon Package",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "version", "publisher", "targets", "dependencies", "artifacts"],
  "properties": {
    "schemaVersion": { "const": "echo.addon.package.v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "version": { "type": "string", "minLength": 1 },
    "publisher": {
      "type": "object",
      "additionalProperties": true,
      "required": ["githubOwner", "githubRepo"],
      "properties": {
        "githubOwner": { "type": "string", "minLength": 1 },
        "githubRepo": { "type": "string", "minLength": 1 }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["native", "neoforge", "standalone"] },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["product", "modpack", "module", "addon", "runtime", "studio", "website"] },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "native": { "type": "string", "pattern": "^[^/\\\\]+\\.echo-addon$" },
        "neoforge": { "type": "string", "pattern": "^[^/\\\\]+-neoforge\\.jar$" },
        "standalone": { "type": "string", "pattern": "^[^/\\\\]+-standalone\\.jar$" },
        "sources": { "type": "string", "pattern": "^[^/\\\\]+-sources\\.jar$" }
      }
    }
  }
}
