{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/knoxhack/ECHO-Release-Index/main/schemas/product-update-entry.schema.json",
  "title": "ECHO Product Update Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "kind",
    "version",
    "channel",
    "publisher",
    "sourceRepo",
    "releaseTag",
    "commitSha",
    "artifacts",
    "dependencies",
    "compatibility",
    "trust",
    "validation"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["product", "runtime", "studio", "website"] },
    "version": { "type": "string", "minLength": 1 },
    "channel": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "sourceRepo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "releaseTag": { "type": "string", "minLength": 1 },
    "commitSha": { "type": "string", "pattern": "^(?!0{7,40}$)[a-fA-F0-9]{7,40}$" },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["file", "sha256"],
        "properties": {
          "file": { "type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!\\\\)(?!.*\\.\\.)(?!.*[/\\\\]).+$" },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "url": { "type": "string", "pattern": "^https://(github\\.com|raw\\.githubusercontent\\.com)/" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["product", "modpack", "module", "addon", "runtime", "studio", "website"] },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "compatibility": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sourceRepo": { "type": "string", "minLength": 1 },
        "commitSha": { "type": "string", "pattern": "^(?!0{7,40}$)[a-fA-F0-9]{7,40}$" },
        "workflow": { "type": "string", "minLength": 1 },
        "workflowRef": { "type": "string", "minLength": 1 },
        "verifiedBy": { "type": "string", "minLength": 1 },
        "generatedBy": { "type": "string", "minLength": 1 },
        "attestation": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "action": { "type": "string", "minLength": 1 },
            "subjectChecksums": { "type": "string", "minLength": 1 },
            "sourceDigest": { "type": "string", "minLength": 1 },
            "signerWorkflow": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "trust": {
      "enum": [
        "official",
        "reproducible-build",
        "echo-workflow-built",
        "provenance-attested",
        "source-linked",
        "community",
        "unverified",
        "deprecated",
        "blocked"
      ]
    },
    "validation": { "enum": ["approved", "warning", "rejected", "blocked"] }
  }
}
