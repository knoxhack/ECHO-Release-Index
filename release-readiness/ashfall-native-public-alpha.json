        { "arrayPath": "data.sessionProofs", "itemPath": "id", "everyItemMatches": ".+" },
        { "arrayPath": "data.sessionProofs", "itemPath": "startedAt", "everyItemMatches": ".+" },
        { "arrayPath": "data.sessionProofs", "itemPath": "startedAt", "everyItemNotEquals": "1970-01-01T00:00:00Z" },
        { "arrayPath": "data.sessionProofs", "itemPath": "startedAt", "everyItemIsoTimestamp": true, "everyItemTimestampOnOrAfter": "2026-06-01T00:00:00Z" },
        { "arrayPath": "data.sessionProofs", "itemPath": "endedAt", "everyItemMatches": ".+" },
        { "arrayPath": "data.sessionProofs", "itemPath": "endedAt", "everyItemNotEquals": "1970-01-01T00:00:00Z" },
        { "arrayPath": "data.sessionProofs", "itemPath": "endedAt", "everyItemIsoTimestamp": true, "everyItemTimestampOnOrAfter": "2026-06-01T00:00:00Z" },
        { "arrayPath": "data.sessionProofs", "itemPath": "endedAt", "everyItemTimestampOnOrAfterPath": "startedAt" },
        { "arrayPath": "data.sessionProofs", "itemPath": "durationMinutes", "everyItemAtLeast": 1 },
        { "arrayPath": "data.sessionProofs", "itemPath": "buildId", "everyItemMatches": ".+" },
        { "arrayPath": "data.sessionProofs", "itemPath": "buildId", "everyItemEqualsJsonValue": true, "jsonFilePath": "reports/echo-native/ashfall/public-beta-tester-package-readiness.json", "jsonValuePath": "data.releaseCandidate.buildId" },
        { "arrayPath": "data.sessionProofs", "itemPath": "artifactSha256", "everyItemMatches": "^[a-f0-9]{64}$" },
        { "arrayPath": "data.sessionProofs", "itemPath": "artifactSha256", "everyItemEqualsJsonValue": true, "jsonFilePath": "reports/echo-native/ashfall/public-beta-tester-package-readiness.json", "jsonValuePath": "data.releaseCandidate.artifactSha256" },
        { "arrayPath": "data.sessionProofs", "itemPath": "noCrash", "everyItemEquals": true },
        { "arrayPath": "data.sessionProofs", "uniqueItemPath": "logPath" },
        { "arrayPath": "data.sessionProofs", "uniqueItemPath": "notesPath" },
        { "arrayPath": "data.sessionProofs", "uniqueItemPath": "supportBundlePath" },
        { "arrayPath": "data.sessionProofs", "itemPath": "logPath", "everyItemFileExists": true },
        { "arrayPath": "data.sessionProofs", "itemPath": "notesPath", "everyItemFileExists": true },
        { "arrayPath": "data.sessionProofs", "itemPath": "supportBundlePath", "everyItemFileExists": true },
        { "arrayPath": "data.sessionProofs", "itemPath": "logPath", "everyItemFileMinBytes": 1 },
        { "arrayPath": "data.sessionProofs", "itemPath": "notesPath", "everyItemFileMinBytes": 1 },
        { "arrayPath": "data.sessionProofs", "itemPath": "supportBundlePath", "everyItemFileMinBytes": 1 },
        { "arrayPath": "data.sessionProofs", "itemPath": "supportBundlePath", "everyItemZipSignature": true },
        { "path": "generatedAt", "notEquals": "1970-01-01T00:00:00Z", "isoTimestamp": true, "timestampOnOrAfter": "2026-06-01T00:00:00Z" }
      ]
    },
    {
      "phase": 7,
      "id": "native-beta-crash-intake",
      "title": "Crash And Support Evidence",
