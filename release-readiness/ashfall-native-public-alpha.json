{
  "schemaVersion": "echo.ashfall.release-readiness.v1",
  "id": "ashfall-native-public-alpha",
  "packId": "ashfall-native-edition",
  "releaseTag": "v0.1.0-ashfall-native-edition",
  "summary": "Machine-checkable release evidence for promoting Ashfall Native Edition from warning metadata to a release-ready public alpha.",
  "checks": [
    {
      "phase": 1,
      "id": "release-freeze",
      "title": "Release Freeze",
      "source": "release-index",
      "path": "modpacks/ashfall-native.json",
      "expect": [
        { "path": "id", "equals": "ashfall-native-edition" },
        { "path": "channel", "equals": "alpha" },
        { "path": "releaseTag", "matches": "^v[0-9]+\\.[0-9]+\\.[0-9]+-ashfall-native-edition$" },
        { "path": "sourceRepo", "equals": "knoxhack/ECHO-Ashfall-Native-Edition" }
      ]
    },
    {
      "phase": 2,
      "id": "native-artifact-truth",
      "title": "Artifact Truth",
      "source": "release-index",
      "path": "modpacks/ashfall-native.json",
      "expect": [
        { "path": "validation", "equals": "approved" },
        { "path": "artifacts.pack.file", "matches": "^ashfall-native-edition-.+\\.zip$" },
        { "path": "artifacts.pack.file", "notMatches": "echo-native-product|existing-layout|placeholder" },
        { "path": "artifacts.manifest.file", "matches": "\\.pack\\.json$" },
        { "path": "artifacts.releaseManifest.file", "equals": "echo-release.json" },
        { "path": "artifacts.checksums.file", "matches": "^checksums\\.(txt|sha256)$" }
      ]
    },
    {
      "phase": 3,
      "id": "launcher-pack-metadata",
      "title": "Release Index Consistency",
      "source": "release-index",
      "path": "packs/ashfall-native-edition.json",
      "expect": [
        { "path": "releaseReadiness.status", "equals": "approved" },
        { "path": "releaseReadiness.blockers", "maxItems": 0 },
        { "arrayPath": "assets", "assetNameMatches": "^echo-release\\.json$" },
        { "arrayPath": "assets", "assetNameMatches": "\\.pack\\.json$" },
        { "arrayPath": "assets", "assetNameMatches": "^ashfall-native-edition-.+\\.zip$" }
      ]
    },
    {
      "phase": 4,
      "id": "required-module-closure",
      "title": "Required Module Closure",
      "source": "release-index",
      "path": "tmp/public-alpha-assets/ECHO-Modules/echo-release.json",
      "expect": [
        { "path": "schemaVersion", "equals": "echo.module.release.v1" },
        { "path": "modules", "minItems": 10 },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echocore" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoplatformcore" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoadaptercore" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echonetcore" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoruntimeguard" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echolens" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echopresencelink" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoterminal" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoblockworks" },
        { "arrayPath": "modules", "itemPath": "moduleId", "contains": "echoashfallprotocol" }
      ]
    },
    {
      "phase": 5,
      "id": "native-code-gate",
      "title": "Native Code Gate Fix",
      "source": "native-platform",
      "path": "reports/echo-native/ashfall/native-code-gate.json",
      "expect": [
        { "path": "schemaVersion", "equals": "echo.ashfall.native-code-gate.v1" },
        { "path": "status", "oneOf": ["PASS", "PASS_WITH_WARNINGS"] },
        { "path": "summary.dryRunOnly", "equals": false },
        { "path": "summary.commandExecuted", "equals": true },
        { "path": "data.gradleCheckPassed", "equals": true },
        { "path": "data.commandExecuted", "equals": true },
        { "path": "data.exitCode", "equals": 0 },
        { "path": "generatedAt", "notEquals": "1970-01-01T00:00:00Z", "isoTimestamp": true, "timestampOnOrAfter": "2026-06-01T00:00:00Z" }
      ]
    },
    {
      "phase": 6,
      "id": "module-artifact-build",
      "title": "Module Artifact Build",
      "source": "release-index",
      "path": "tmp/public-alpha-assets/ECHO-Modules/echo-release.json",
      "expect": [
        { "path": "modules", "minItems": 10 },
        { "arrayPath": "modules", "itemPath": "artifacts", "everyArrayMinItems": 4 },
        { "arrayPath": "modules", "itemPath": "artifacts", "everyNestedPathEquals": { "path": "buildMode", "value": "compiled-runtime", "where": { "path": "kind", "notEquals": "sources" } } }
      ]
    },
    {
      "phase": 7,
